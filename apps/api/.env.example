# === DATABASE CONNECTIONS (REQUIRED) ===
# Update passwords to match docker-compose credentials
DATABASE_URL=postgresql+asyncpg://continuum:your_postgres_password@localhost:5432/continuum
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
REDIS_URL=redis://:your_redis_password@localhost:6379

# === LLM PROVIDER ===
# Default: Ollama (local, no API keys needed)
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama
OLLAMA_HOST=http://ollama:11434

# === NVIDIA NIM API (alternative — uncomment if using nvidia provider) ===
# NVIDIA_API_KEY=nvapi-xxxx
# NVIDIA_EMBEDDING_API_KEY=nvapi-xxxx

# === AUTH (REQUIRED) ===
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT: Must match NEXTAUTH_SECRET in the frontend for JWT validation
SECRET_KEY=CHANGE_ME_must_match_nextauth_secret

# === APP SETTINGS ===
DEBUG=false
CORS_ORIGINS=["http://localhost:3000"]
